{
	"name": "drago-ex/authorization",
	"type": "library",
	"description": "A simple dynamic access control list (ACL) management system for Nette Framework, with support for roles, permissions, and resources",
	"license": ["MIT"],
	"authors": [
		{
			"name": "Zdeněk Papučík",
			"homepage": "https://github.com/accgit"
		}
	],
	"require": {
		"php": ">=8.3 <9",
		"nette/security": "^3.1",
		"nette/application": "^3.1",
		"nette/caching": "^3.2",
		"nette/di": "^3.1",
		"latte/latte": "^3.0",
		"drago-ex/database": "^3.0",
		"drago-ex/application": "^2.0",
		"drago-ex/utils": "^2.0",
		"ublaboo/datagrid": "dev-master"
	},
	"require-dev": {
		"nette/tester": "^2.5",
		"nette/bootstrap": "^3.2",
		"tracy/tracy": "^2.10",
		"phpstan/phpstan-nette": "^2.0"
	},
	"autoload": {
		"classmap": ["src/"]
	},
	"scripts": {
		"phpstan": "phpstan analyse",
		"tester": "tester tests -s"
	}
}
